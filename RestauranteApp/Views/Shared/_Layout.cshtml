@{
    var clienteId = Context.Session.GetInt32("ClienteId");
    var admin = Context.Session.GetInt32("Admin") == 1;
    var clienteNome = Context.Session.GetString("ClienteNome");
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RestauranteApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RestauranteApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand text-white fw-bold" asp-area="" asp-controller="Home" asp-action="Index">RestauranteApp</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Alternar navegação">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (clienteId == null)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Auth" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Auth" asp-action="Register">Cadastro</a>
                            </li>
                        }
                        else if (admin)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="SugestaoChefes" asp-action="Index">Sugestão do Chefe</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Pedidos" asp-action="Index">Pedidos</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Reservas" asp-action="Index">Reservas</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Relatorios" asp-action="Index">Relatórios</a>
                            </li>

                            <li class="nav-item">
                                <span class="nav-link text-white">Olá, @clienteNome (Admin)</span>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Auth" asp-action="Logout">Sair</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Pedidos" asp-action="Index">Pedidos</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Enderecos" asp-action="Index">Endereços</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Reservas" asp-action="Index">Reservas</a>
                            </li>

                            <li class="nav-item">
                                <span class="nav-link text-white">Olá, @clienteNome</span>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Auth" asp-action="Logout">Sair</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - RestauranteApp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@model RestauranteApp.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Cadastro";
}

<div class="login-body">
    <div class="login-container">
        <div class="login-card shadow">

            <div class="text-center mb-3">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">← Voltar ao Início</a>
            </div>

            <h2 class="text-center mb-3">🍽 Restaurante</h2>
            <p class="text-center text-muted mb-4">Crie sua conta</p>

            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input asp-for="Nome" class="form-control mb-3" placeholder="Nome completo" />
                <span asp-validation-for="Nome" class="text-danger"></span>

                <input asp-for="Email" class="form-control mb-3" placeholder="Email" />
                <span asp-validation-for="Email" class="text-danger"></span>

                <input asp-for="Senha" class="form-control mb-3" type="password" placeholder="Senha" />
                <span asp-validation-for="Senha" class="text-danger"></span>

                <input asp-for="ConfirmarSenha" class="form-control mb-3" type="password" placeholder="Confirmar senha" />
                <span asp-validation-for="ConfirmarSenha" class="text-danger"></span>

                <input asp-for="Telefone" class="form-control mb-3" placeholder="Telefone" />
                <span asp-validation-for="Telefone" class="text-danger"></span>

                <button type="submit" class="btn btn-primary w-100">Cadastrar</button>
            </form>

            <div class="text-center mt-3">
                <small>Já tem conta? <a asp-controller="Auth" asp-action="Login">Entrar</a></small>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
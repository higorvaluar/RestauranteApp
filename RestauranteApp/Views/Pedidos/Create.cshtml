@model RestauranteApp.ViewModels.PedidoCreateViewModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Pedido</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="DataPedido" class="control-label"></label>
                <input asp-for="DataPedido" class="form-control" />
                <span asp-validation-for="DataPedido" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Periodo" class="control-label"></label>
                <select asp-for="Periodo" class="form-control"
                        asp-items="Html.GetEnumSelectList<RestauranteApp.Models.PeriodoEnum>()">
                </select>
                <span asp-validation-for="Periodo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ClienteId" class="control-label"></label>
                <select asp-for="ClienteId" class="form-control" asp-items="ViewBag.ClienteId"></select>
                <span asp-validation-for="ClienteId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TipoAtendimento" class="control-label"></label>
                <select asp-for="TipoAtendimento" class="form-control">
                    <option value="Presencial">Presencial</option>
                    <option value="DeliveryProprio">Delivery Próprio</option>
                    <option value="DeliveryAplicativo">Delivery por Aplicativo</option>
                </select>
                <span asp-validation-for="TipoAtendimento" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TaxaEntrega" class="control-label"></label>
                <input asp-for="TaxaEntrega" class="form-control" />
                <span asp-validation-for="TaxaEntrega" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EnderecoEntrega" class="control-label"></label>
                <input asp-for="EnderecoEntrega" class="form-control" />
                <span asp-validation-for="EnderecoEntrega" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="NomeAplicativo" class="control-label"></label>
                <input asp-for="NomeAplicativo" class="form-control" />
                <span asp-validation-for="NomeAplicativo" class="text-danger"></span>
            </div>

            <hr />
            <h5>Itens do Pedido</h5>

            @for (int i = 0; i < Model.Itens.Count; i++)
            {
                <div class="border rounded p-3 mb-3">
                    <div class="form-group mb-2">
                        <label asp-for="Itens[i].ProdutoId" class="control-label">Produto</label>
                        <select asp-for="Itens[i].ProdutoId" class="form-control" asp-items="ViewBag.Produtos">
                            <option value="">Selecione um produto</option>
                        </select>
                        <span asp-validation-for="Itens[i].ProdutoId" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Itens[i].Quantidade" class="control-label">Quantidade</label>
                        <input asp-for="Itens[i].Quantidade" class="form-control" />
                        <span asp-validation-for="Itens[i].Quantidade" class="text-danger"></span>
                    </div>
                </div>
            }

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
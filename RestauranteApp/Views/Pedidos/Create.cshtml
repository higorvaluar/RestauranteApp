@model RestauranteApp.ViewModels.PedidoCreateViewModel
@using RestauranteApp.Models
@using System.Text.Json

@{
    ViewData["Title"] = "Criar Pedido";

    var produtos = ViewBag.Produtos as List<Produto> ?? new List<Produto>();

    var produtosJson = JsonSerializer.Serialize(
        produtos.Select(p => new
        {
            id = p.Id,
            nome = p.Nome,
            periodo = (int)p.Periodo
        })
    );
}

<h1>Criar Pedido</h1>

<h4>Pedido</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input asp-for="ClienteId" type="hidden" />

            <div class="form-group mb-3">
                <label asp-for="DataPedido" class="control-label">Data do Pedido</label>
                <input asp-for="DataPedido" class="form-control" readonly />
                <span asp-validation-for="DataPedido" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Periodo" class="control-label">Período</label>
                <select asp-for="Periodo"
                        id="Periodo"
                        class="form-control"
                        asp-items="Html.GetEnumSelectList<PeriodoEnum>()">
                </select>
                <span asp-validation-for="Periodo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Cliente</label>
                <input class="form-control" value="@ViewBag.ClienteNome" readonly />
            </div>

            <div class="form-group mb-3">
                <label asp-for="TipoAtendimento" class="control-label">Tipo de Atendimento</label>
                <select asp-for="TipoAtendimento" class="form-control">
                    <option value="Presencial">Presencial</option>
                    <option value="DeliveryProprio">Delivery Próprio</option>
                    <option value="DeliveryAplicativo">Delivery por Aplicativo</option>
                </select>
                <span asp-validation-for="TipoAtendimento" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Taxa Fixa do Delivery Próprio</label>
                <input class="form-control" value="R$ @ViewBag.TaxaFixaDeliveryProprio" readonly />
            </div>

            <div class="form-group mb-3">
                <label asp-for="EnderecoId" class="control-label">Endereço de Entrega</label>
                <select asp-for="EnderecoId" class="form-control" asp-items="ViewBag.Enderecos">
                    <option value="">Selecione um endereço</option>
                </select>
                <span asp-validation-for="EnderecoId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="NomeAplicativo" class="control-label">Aplicativo</label>
                <input asp-for="NomeAplicativo" class="form-control" />
                <span asp-validation-for="NomeAplicativo" class="text-danger"></span>
            </div>

            <hr />
            <h5>Itens do Pedido</h5>

            @for (int i = 0; i < Model.Itens.Count; i++)
            {
                <div class="border rounded p-3 mb-3">
                    <div class="form-group mb-2">
                        <label asp-for="Itens[i].ProdutoId" class="control-label">Produto</label>
                        <select asp-for="Itens[i].ProdutoId"
                                class="form-control produto-select"
                                data-selected="@(Model.Itens[i].ProdutoId?.ToString() ?? "")">
                            <option value="">Selecione um produto</option>
                        </select>
                        <span asp-validation-for="Itens[i].ProdutoId" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Itens[i].Quantidade" class="control-label">Quantidade</label>
                        <input asp-for="Itens[i].Quantidade" class="form-control" />
                        <span asp-validation-for="Itens[i].Quantidade" class="text-danger"></span>
                    </div>
                </div>
            }

            <div class="form-group">
                <input type="submit" value="Criar Pedido" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Voltar para a lista</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const produtos = @Html.Raw(produtosJson);
        const periodoSelect = document.getElementById("Periodo");

        function preencherSelectProduto(select, limparSelecao) {
            const periodoSelecionado = String(periodoSelect.value);
            const valorAtual = limparSelecao ? "" : (select.dataset.selected || select.value || "");

            select.innerHTML = '<option value="">Selecione um produto</option>';

            const filtrados = produtos.filter(p => String(p.periodo) === periodoSelecionado);

            for (const produto of filtrados) {
                const option = document.createElement("option");
                option.value = produto.id;
                option.textContent = produto.nome;
                select.appendChild(option);
            }

            const existeValor = filtrados.some(p => String(p.id) === String(valorAtual));

            if (existeValor) {
                select.value = String(valorAtual);
            } else {
                select.value = "";
            }

            select.dataset.selected = "";
        }

        function preencherTodosOsProdutos(limparSelecao) {
            const selects = document.querySelectorAll(".produto-select");

            for (const select of selects) {
                preencherSelectProduto(select, limparSelecao);
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            preencherTodosOsProdutos(false);

            periodoSelect.addEventListener("change", function () {
                preencherTodosOsProdutos(true);
            });
        });
    </script>
}
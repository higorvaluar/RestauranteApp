@model RestauranteApp.ViewModels.PedidoCreateViewModel
@using RestauranteApp.Models
@using System.Text.Json

@{
    ViewData["Title"] = "Criar Pedido";

    var produtos = ViewBag.Produtos as List<Produto> ?? new List<Produto>();

    var produtosJson = JsonSerializer.Serialize(
        produtos.Select(p => new
        {
            id = p.Id,
            nome = p.Nome,
            periodo = (int)p.Periodo,
            preco = p.Preco.ToString("F2")
        })
    );
}

<div class="container py-4">
    <div class="section-header mb-4">
        <div>
            <h1 class="section-title">Criar Pedido</h1>
            <p class="mb-0 text-muted">Escolha o período, o tipo de atendimento e os itens do pedido.</p>
        </div>

        <a asp-action="Index" class="btn btn-outline-danger">
            Voltar
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <input asp-for="ClienteId" type="hidden" />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="DataPedido" class="form-label">Data do Pedido</label>
                                <input asp-for="DataPedido" class="form-control" readonly />
                                <span asp-validation-for="DataPedido" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Periodo" class="form-label">Período</label>
                                <select asp-for="Periodo"
                                        id="Periodo"
                                        class="form-select"
                                        asp-items="Html.GetEnumSelectList<PeriodoEnum>()">
                                </select>
                                <span asp-validation-for="Periodo" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Cliente</label>
                                <input class="form-control" value="@ViewBag.ClienteNome" readonly />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="TipoAtendimento" class="form-label">Tipo de Atendimento</label>
                                <select asp-for="TipoAtendimento" id="TipoAtendimento" class="form-select">
                                    <option value="Presencial">Presencial</option>
                                    <option value="DeliveryProprio">Delivery Próprio</option>
                                    <option value="DeliveryAplicativo">Delivery por Aplicativo</option>
                                </select>
                                <span asp-validation-for="TipoAtendimento" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="alert alert-light border mt-4 mb-4">
                            <strong>Taxas:</strong>
                            Delivery próprio tem taxa fixa de <strong>R$ @ViewBag.TaxaFixaDeliveryProprio</strong>.
                            Delivery por aplicativo cobra 4% no almoço e 6% no jantar.
                        </div>

                        <div id="campoEndereco" class="mb-3">
                            <label asp-for="EnderecoId" class="form-label">Endereço de Entrega</label>
                            <select asp-for="EnderecoId" class="form-select" asp-items="ViewBag.Enderecos">
                                <option value="">Selecione um endereço</option>
                            </select>
                            <span asp-validation-for="EnderecoId" class="text-danger"></span>
                        </div>

                        <div id="campoAplicativo" class="mb-3">
                            <label asp-for="NomeAplicativo" class="form-label">Aplicativo</label>
                            <input asp-for="NomeAplicativo" class="form-control" placeholder="Ex: iFood, AppX" />
                            <span asp-validation-for="NomeAplicativo" class="text-danger"></span>
                        </div>

                        <hr class="my-4" />

                        <h4 class="mb-3">Itens do Pedido</h4>

                        <div class="row g-3">
                            @for (int i = 0; i < Model.Itens.Count; i++)
                            {
                                <div class="col-md-4">
                                    <div class="card h-100 shadow-sm">
                                        <div class="card-body">
                                            <h5 class="card-title">Item @(i + 1)</h5>

                                            <div class="mb-3">
                                                <label asp-for="Itens[i].ProdutoId" class="form-label">Produto</label>
                                                <select asp-for="Itens[i].ProdutoId"
                                                        class="form-select produto-select"
                                                        data-selected="@(Model.Itens[i].ProdutoId?.ToString() ?? "")">
                                                    <option value="">Selecione um produto</option>
                                                </select>
                                                <span asp-validation-for="Itens[i].ProdutoId" class="text-danger"></span>
                                            </div>

                                            <div class="mb-3">
                                                <label asp-for="Itens[i].Quantidade" class="form-label">Quantidade</label>
                                                <input asp-for="Itens[i].Quantidade" class="form-control" min="0" />
                                                <span asp-validation-for="Itens[i].Quantidade" class="text-danger"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mt-4">
                            Finalizar Pedido
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm sticky-top" style="top: 90px;">
                <div class="card-body">
                    <h4 class="card-title">Resumo</h4>

                    <p class="text-muted mb-3">
                        Os produtos são filtrados automaticamente conforme o período escolhido.
                    </p>

                    <ul class="mb-0">
                        <li>Almoço só aceita itens de almoço.</li>
                        <li>Jantar só aceita itens de jantar.</li>
                        <li>Delivery próprio exige endereço.</li>
                        <li>Delivery por aplicativo exige nome do aplicativo.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const produtos = @Html.Raw(produtosJson);

        const periodoSelect = document.getElementById("Periodo");
        const tipoAtendimentoSelect = document.getElementById("TipoAtendimento");
        const campoEndereco = document.getElementById("campoEndereco");
        const campoAplicativo = document.getElementById("campoAplicativo");

        function preencherSelectProduto(select, limparSelecao) {
            const periodoSelecionado = String(periodoSelect.value);
            const valorAtual = limparSelecao ? "" : (select.dataset.selected || select.value || "");

            select.innerHTML = '<option value="">Selecione um produto</option>';

            const filtrados = produtos.filter(p => String(p.periodo) === periodoSelecionado);

            for (const produto of filtrados) {
                const option = document.createElement("option");
                option.value = produto.id;
                option.textContent = `${produto.nome} - R$ ${produto.preco}`;
                select.appendChild(option);
            }

            const existeValor = filtrados.some(p => String(p.id) === String(valorAtual));

            if (existeValor) {
                select.value = String(valorAtual);
            } else {
                select.value = "";
            }

            select.dataset.selected = "";
        }

        function preencherTodosOsProdutos(limparSelecao) {
            const selects = document.querySelectorAll(".produto-select");

            for (const select of selects) {
                preencherSelectProduto(select, limparSelecao);
            }
        }

        function atualizarCamposAtendimento() {
            const tipo = tipoAtendimentoSelect.value;

            if (tipo === "DeliveryProprio") {
                campoEndereco.style.display = "block";
                campoAplicativo.style.display = "none";
            } else if (tipo === "DeliveryAplicativo") {
                campoEndereco.style.display = "none";
                campoAplicativo.style.display = "block";
            } else {
                campoEndereco.style.display = "none";
                campoAplicativo.style.display = "none";
            }
        }

        preencherTodosOsProdutos(false);
        atualizarCamposAtendimento();

        periodoSelect.addEventListener("change", function () {
            preencherTodosOsProdutos(true);
        });

        tipoAtendimentoSelect.addEventListener("change", atualizarCamposAtendimento);
    </script>
}
@model IEnumerable<RestauranteApp.Models.Pedido>

@{
    ViewData["Title"] = "Pedidos";
    var admin = Context.Session.GetInt32("Admin") == 1;
}

<h1>Pedidos</h1>

@if (!admin)
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Novo Pedido</a>
    </p>
}

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Data do Pedido</th>
            <th>Cliente</th>
            <th>Período</th>
            <th>Atendimento</th>
            <th>Pratos</th>
            <th>Total</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.DataPedido</td>
                <td>@item.Cliente.Nome</td>
                <td>@item.Periodo</td>
                <td>@item.Atendimento?.Tipo</td>
                <td>
                    @if (item.PedidoItens != null && item.PedidoItens.Any())
                    {
                        <ul class="mb-0 ps-3">
                            @foreach (var pedidoItem in item.PedidoItens)
                            {
                                var precoBaseTotal = pedidoItem.PrecoUnitario * pedidoItem.Quantidade;
                                var temDesconto = pedidoItem.Subtotal < precoBaseTotal;
                                var precoComDescontoUnitario = pedidoItem.Quantidade > 0
                                    ? pedidoItem.Subtotal / pedidoItem.Quantidade
                                    : pedidoItem.PrecoUnitario;

                                <li>
                                    <strong>@pedidoItem.Produto.Nome</strong>
                                    - Qtd: @pedidoItem.Quantidade

                                    @if (temDesconto)
                                    {
                                        <span>
                                            - <strong class="text-success">Sugestão do Chefe (-20%)</strong>
                                            - Preço base: R$ @pedidoItem.PrecoUnitario.ToString("F2")
                                            - Com desconto: R$ @precoComDescontoUnitario.ToString("F2")
                                            - Subtotal: R$ @pedidoItem.Subtotal.ToString("F2")
                                        </span>
                                    }
                                    else
                                    {
                                        <span>
                                            - Unitário: R$ @pedidoItem.PrecoUnitario.ToString("F2")
                                            - Subtotal: R$ @pedidoItem.Subtotal.ToString("F2")
                                        </span>
                                    }
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <span>Sem itens</span>
                    }
                </td>
                <td>R$ @item.Total.ToString("F2")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Detalhes</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>
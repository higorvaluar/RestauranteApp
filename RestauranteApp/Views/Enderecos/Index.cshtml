@model IEnumerable<RestauranteApp.Models.Endereco>

@{
    ViewData["Title"] = "Meus Endereços";
}

<h1>Meus Endereços</h1>

<p>
    <a asp-action="Create">Cadastrar Novo Endereço</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Rua</th>
            <th>Número</th>
            <th>Cidade</th>
            <th>Estado</th>
            <th>CEP</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Rua</td>
                <td>@item.Numero</td>
                <td>@item.Cidade</td>
                <td>@item.Estado</td>
                <td>@item.CEP</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
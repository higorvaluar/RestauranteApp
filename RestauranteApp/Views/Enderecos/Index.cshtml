@model IEnumerable<RestauranteApp.Models.Endereco>

@{
    ViewData["Title"] = "Meus Endereços";
}

<div class="container py-4">
    <div class="section-header mb-4">
        <div>
            <h1 class="section-title">Meus Endereços</h1>
            <p class="mb-0 text-muted">Gerencie seus endereços de entrega.</p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            Cadastrar Endereço
        </a>
    </div>

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@item.Rua, @item.Numero</h5>

                            <p class="card-text mb-1">
                                <strong>Cidade:</strong> @item.Cidade
                            </p>

                            <p class="card-text mb-1">
                                <strong>Estado:</strong> @item.Estado
                            </p>

                            <p class="card-text mb-3">
                                <strong>CEP:</strong> @item.CEP
                            </p>

                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">
                                    Editar
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">
                                    Excluir
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <h4>Nenhum endereço cadastrado</h4>
                <p class="text-muted">Cadastre um endereço para usar em pedidos com delivery próprio.</p>

                <a asp-action="Create" class="btn btn-primary">
                    Cadastrar meu primeiro endereço
                </a>
            </div>
        </div>
    }
</div>
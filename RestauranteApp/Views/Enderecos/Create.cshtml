@model RestauranteApp.Models.Endereco

@{
    ViewData["Title"] = "Cadastrar Endereço";
}

<div class="container py-4">
    <div class="section-header mb-4">
        <div>
            <h1 class="section-title">Cadastrar Endereço</h1>
            <p class="mb-0 text-muted">Adicione um endereço para pedidos com delivery próprio.</p>
        </div>

        <a asp-action="Index" class="btn btn-outline-danger">
            Voltar
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Rua" class="form-label">Rua</label>
                            <input asp-for="Rua" class="form-control" placeholder="Ex: Avenida JK" />
                            <span asp-validation-for="Rua" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Numero" class="form-label">Número</label>
                            <input asp-for="Numero" class="form-control" placeholder="Ex: 123" />
                            <span asp-validation-for="Numero" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Cidade" class="form-label">Cidade</label>
                            <input asp-for="Cidade" class="form-control" placeholder="Ex: Palmas" />
                            <span asp-validation-for="Cidade" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Estado" class="form-label">Estado</label>
                            <input asp-for="Estado" class="form-control" placeholder="Ex: TO ou Tocantins" />
                            <span asp-validation-for="Estado" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CEP" class="form-label">CEP</label>
                            <input asp-for="CEP" class="form-control" placeholder="Ex: 77000000" maxlength="8" />
                            <span asp-validation-for="CEP" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            Cadastrar Endereço
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@model RestauranteApp.Models.Endereco

@{
    ViewData["Title"] = "Excluir Endereço";
}

<h1>Excluir Endereço</h1>

<h3>Tem certeza que deseja excluir este endereço?</h3>

<div>
    <dl class="row">
        <dt class="col-sm-2">Rua</dt>
        <dd class="col-sm-10">@Model.Rua</dd>

        <dt class="col-sm-2">Número</dt>
        <dd class="col-sm-10">@Model.Numero</dd>

        <dt class="col-sm-2">Cidade</dt>
        <dd class="col-sm-10">@Model.Cidade</dd>

        <dt class="col-sm-2">Estado</dt>
        <dd class="col-sm-10">@Model.Estado</dd>

        <dt class="col-sm-2">CEP</dt>
        <dd class="col-sm-10">@Model.CEP</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index">Back to List</a>
    </form>
</div>
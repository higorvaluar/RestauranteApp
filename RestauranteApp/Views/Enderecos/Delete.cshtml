@model RestauranteApp.Models.Endereco

@{
    ViewData["Title"] = "Excluir Endereço";
}

<div class="container py-4">
    <div class="section-header mb-4">
        <div>
            <h1 class="section-title">Excluir Endereço</h1>
            <p class="mb-0 text-muted">Confirme se deseja remover este endereço.</p>
        </div>

        <a asp-action="Index" class="btn btn-outline-danger">
            Voltar
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h4 class="mb-3">Tem certeza que deseja excluir este endereço?</h4>

                    <div class="mb-4">
                        <p class="mb-1"><strong>Rua:</strong> @Model.Rua</p>
                        <p class="mb-1"><strong>Número:</strong> @Model.Numero</p>
                        <p class="mb-1"><strong>Cidade:</strong> @Model.Cidade</p>
                        <p class="mb-1"><strong>Estado:</strong> @Model.Estado</p>
                        <p class="mb-0"><strong>CEP:</strong> @Model.CEP</p>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">
                                Excluir
                            </button>

                            <a asp-action="Index" class="btn btn-outline-secondary">
                                Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@model RestauranteApp.Models.SugestaoChefe
@using RestauranteApp.Models
@using System.Text.Json

@{
    ViewData["Title"] = "Cadastrar Sugestão do Chefe";

    var produtos = ViewBag.Produtos as List<Produto> ?? new List<Produto>();

    var produtosJson = JsonSerializer.Serialize(
        produtos.Select(p => new
        {
            id = p.Id,
            nome = p.Nome,
            periodo = (int)p.Periodo
        })
    );

    var produtoSelecionado = Model.ProdutoId == 0 ? "" : Model.ProdutoId.ToString();
}

<h1>Cadastrar Sugestão do Chefe</h1>

<h4>Sugestão do Chefe</h4>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-controller="SugestaoChefes" asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Data" class="control-label"></label>
                <input asp-for="Data" class="form-control" type="date" />
                <span asp-validation-for="Data" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Periodo" class="control-label"></label>
                <select asp-for="Periodo"
                        id="Periodo"
                        class="form-control"
                        asp-items="Html.GetEnumSelectList<PeriodoEnum>()">
                </select>
                <span asp-validation-for="Periodo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ProdutoId" class="control-label">Produto</label>
                <select asp-for="ProdutoId" id="ProdutoId" class="form-control">
                    <option value="">Selecione um produto</option>
                </select>
                <span asp-validation-for="ProdutoId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Desconto</label>
                <input class="form-control" value="20%" readonly />
            </div>

            <div class="form-group">
                <input type="submit" value="Cadastrar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Voltar para a lista</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const produtos = @Html.Raw(produtosJson);
        const periodoSelect = document.getElementById("Periodo");
        const produtoSelect = document.getElementById("ProdutoId");
        const produtoSelecionadoServidor = "@produtoSelecionado";

        function preencherProdutos(limparSelecao) {
            const periodoSelecionado = String(periodoSelect.value);
            const valorDesejado = limparSelecao ? "" : produtoSelecionadoServidor;

            produtoSelect.innerHTML = '<option value="">Selecione um produto</option>';

            const produtosFiltrados = produtos.filter(p => String(p.periodo) === periodoSelecionado);

            for (const produto of produtosFiltrados) {
                const option = document.createElement("option");
                option.value = produto.id;
                option.textContent = produto.nome;
                produtoSelect.appendChild(option);
            }

            if (valorDesejado && produtosFiltrados.some(p => String(p.id) === valorDesejado)) {
                produtoSelect.value = valorDesejado;
            } else {
                produtoSelect.value = "";
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            preencherProdutos(false);

            periodoSelect.addEventListener("change", function () {
                preencherProdutos(true);
            });
        });
    </script>
}
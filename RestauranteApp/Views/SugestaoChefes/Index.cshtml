@model IEnumerable<RestauranteApp.Models.SugestaoChefe>

@{
    ViewData["Title"] = "Sugestões do Chefe";
}

<div class="container py-4">
    <div class="section-header mb-4">
        <div>
            <h1 class="section-title">Sugestões do Chefe</h1>
            <p class="mb-0 text-muted">Gerencie os pratos com desconto especial do dia.</p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            Nova Sugestão
        </a>
    </div>

    <div class="alert alert-light border mb-4">
        <strong>Regra:</strong> cada dia pode ter apenas uma sugestão para almoço e uma sugestão para jantar.
        O desconto aplicado é sempre de <strong>20%</strong>.
    </div>

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model.OrderByDescending(s => s.Data).ThenBy(s => s.Periodo))
            {
                var precoBase = item.Produto?.Preco ?? 0;
                var precoComDesconto = precoBase * (1 - (item.PercentualDesconto / 100));

                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm food-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0">
                                    @(item.Produto?.Nome ?? "Produto não encontrado")
                                </h5>

                                <span class="badge bg-danger">@item.Periodo</span>
                            </div>

                            <p class="mb-1">
                                <strong>Data:</strong> @item.Data.ToString("dd/MM/yyyy")
                            </p>

                            <p class="mb-1">
                                <strong>Desconto:</strong> @item.PercentualDesconto.ToString("F0")%
                            </p>

                            @if (item.Produto != null)
                            {
                                <p class="mb-1">
                                    <strong>Preço base:</strong> R$ @precoBase.ToString("F2")
                                </p>

                                <p class="mb-3">
                                    <strong>Com desconto:</strong> R$ @precoComDesconto.ToString("F2")
                                </p>
                            }

                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">
                                    Editar
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">
                                    Excluir
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <h4>Nenhuma sugestão cadastrada</h4>
                <p class="text-muted">Cadastre uma sugestão para destacar um prato no cardápio.</p>

                <a asp-action="Create" class="btn btn-primary">
                    Cadastrar primeira sugestão
                </a>
            </div>
        </div>
    }
</div>
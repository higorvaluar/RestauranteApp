@model IEnumerable<RestauranteApp.Models.SugestaoChefe>

@{
    ViewData["Title"] = "Sugestões do Chefe";
}

<h1>Sugestões do Chefe</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Nova Sugestão</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Data</th>
            <th>Período</th>
            <th>Desconto</th>
            <th>Produto</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Data.ToString("dd/MM/yyyy")</td>
                <td>@item.Periodo</td>
                <td>@item.PercentualDesconto.ToString("F0")%</td>
                <td>@(item.Produto?.Nome ?? "Produto não encontrado")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Editar</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Detalhes</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>
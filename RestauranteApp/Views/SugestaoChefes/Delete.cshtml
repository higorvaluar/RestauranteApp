@model RestauranteApp.Models.SugestaoChefe

@{
    ViewData["Title"] = "Excluir Sugestão do Chefe";

    var precoBase = Model.Produto?.Preco ?? 0;
    var precoComDesconto = precoBase * (1 - (Model.PercentualDesconto / 100));
}

<div class="container py-4">
    <div class="section-header mb-4">
        <div>
            <h1 class="section-title">Excluir Sugestão do Chefe</h1>
            <p class="mb-0 text-muted">Confirme se deseja remover esta sugestão.</p>
        </div>

        <a asp-action="Index" class="btn btn-outline-danger">
            Voltar
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h4 class="mb-3">Tem certeza que deseja excluir esta sugestão?</h4>

                    <div class="mb-4">
                        <p class="mb-1"><strong>Data:</strong> @Model.Data.ToString("dd/MM/yyyy")</p>
                        <p class="mb-1"><strong>Período:</strong> @Model.Periodo</p>
                        <p class="mb-1"><strong>Produto:</strong> @(Model.Produto?.Nome ?? "Produto não encontrado")</p>
                        <p class="mb-1"><strong>Desconto:</strong> @Model.PercentualDesconto.ToString("F0")%</p>

                        @if (Model.Produto != null)
                        {
                            <p class="mb-1"><strong>Preço base:</strong> R$ @precoBase.ToString("F2")</p>
                            <p class="mb-0"><strong>Com desconto:</strong> R$ @precoComDesconto.ToString("F2")</p>
                        }
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">
                                Excluir
                            </button>

                            <a asp-action="Index" class="btn btn-outline-secondary">
                                Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
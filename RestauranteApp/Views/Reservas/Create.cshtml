@model RestauranteApp.Models.Reserva

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Reserva</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="All" class="text-danger"></div>

            <input asp-for="ClienteId" type="hidden" />

            <div class="form-group mb-3">
                <label class="control-label">Cliente</label>
                <input class="form-control" value="@ViewBag.ClienteNome" readonly />
            </div>

            <div class="form-group mb-3">
                <label asp-for="DataReserva" class="control-label"></label>
                <input asp-for="DataReserva"
                       asp-format="{0:yyyy-MM-ddTHH:mm}"
                       class="form-control"
                       type="datetime-local" />
                <span asp-validation-for="DataReserva" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="QuantidadePessoas" class="control-label"></label>
                <input asp-for="QuantidadePessoas" class="form-control" />
                <span asp-validation-for="QuantidadePessoas" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="MesaId" class="control-label"></label>
                <select asp-for="MesaId" class="form-control" asp-items="ViewBag.MesaId"></select>
                <span asp-validation-for="MesaId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}